{
  "name": "nebulosa-host-tools",
  "version": "1.0.0",
  "description": "HostPilot userscript — build tooling and unit tests",
  "private": true,
  "scripts": {
    "test": "jest --no-coverage",
    "build": "node scripts/build-userscript.js",
    "build:doppler": "doppler run -- node scripts/build-userscript.js",
    "build:dev": "NODE_ENV=development node scripts/build-userscript.js",
    "build:prod": "NODE_ENV=production node scripts/build-userscript.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
