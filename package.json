{
  "name": "zoom-host-automation",
  "version": "1.0.0",
  "description": "Build tooling for the Zoom Web host automation userscript",
  "private": true,
  "scripts": {
    "generate-selectors": "node scripts/generate-selectors.js",
    "validate-selectors": "node scripts/validate-selectors.js",
    "prebuild": "node scripts/generate-selectors.js",
    "build": "node scripts/build-userscript.js",
    "build:doppler": "doppler run -- node scripts/build-userscript.js",
    "test": "jest --testPathPattern=tests/"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}