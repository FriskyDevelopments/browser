# ──────────────────────────────────────────────────────────────────────────────
# Nebulosa / Lightpanda — Secret & Configuration Reference
# ──────────────────────────────────────────────────────────────────────────────
#
# PURPOSE
# -------
# This file documents every environment variable consumed by:
#   • The Zoom host-tool userscripts (scripts/)
#   • The Lightpanda browser engine (src/)
#   • The CI/CD pipelines (.github/workflows/)
#
# HOW TO USE
# ----------
# Option A — Doppler (recommended):
#   1. doppler login
#   2. doppler setup          # select project "nebulosa" and your config
#   3. doppler run -- node scripts/build-userscript.js
#
# Option B — Local .env file (development only):
#   cp config/secrets.env.example .env
#   # Fill in the values for your environment
#   # The build script will automatically load .env if Doppler is not available
#
# ⚠️  NEVER commit a file containing real secret values to source control.
# ──────────────────────────────────────────────────────────────────────────────


# ══════════════════════════════════════════════════════════════════════════════
# ZOOM HOST-TOOL CONFIGURATION
# Consumed by: scripts/build-userscript.js → dist/zoom-host-tools.user.js
#                                           → dist/zoom-host-automation.user.js
# ══════════════════════════════════════════════════════════════════════════════

# Enable verbose [DEBUG] log output in the browser console.
# Keep false in production to avoid leaking diagnostic info in the console.
ZOOM_HOST_DEBUG_MODE=false

# How often (ms) the DOM fallback polls for raised hands and camera state.
# Lower values are more responsive but may increase CPU usage.
ZOOM_HOST_POLL_INTERVAL_MS=2000

# How often (ms) the chat monitor polls for new messages (Phase 3).
ZOOM_HOST_CHAT_POLL_INTERVAL_MS=3000

# Delay (ms) between successive UI interaction steps when driving a participant
# context menu (e.g. open menu → wait → click action).
ZOOM_HOST_ACTION_DELAY_MS=500

# Maximum retries for opening a participant's context menu before giving up.
ZOOM_HOST_MAX_MENU_RETRIES=3

# Maximum ms to wait for the Zoom meeting UI to appear before abandoning
# the bootstrap sequence.
ZOOM_HOST_BOOTSTRAP_TIMEOUT_MS=60000

# Maximum characters of a chat message to include in console log snippets.
ZOOM_HOST_LOG_MESSAGE_MAX_LENGTH=80

# Number of warnings to issue before escalating to waiting-room removal.
# Set to 0 to skip warnings and escalate immediately.
ZOOM_HOST_WARN_BEFORE_ESCALATE=2

# Comma-separated list of phrases that trigger chat moderation (Phase 3).
# Matching is case-insensitive with word-boundary anchors (\b).
ZOOM_HOST_SPAM_WORDS=buy now,click here,free money,earn cash,discount code

# Feature-flag each automation phase independently.
# Set to "true" to enable or "false" to disable.
ZOOM_HOST_PHASE_RAISED_HAND=true
ZOOM_HOST_PHASE_CAMERA_CHECK=true
ZOOM_HOST_PHASE_CHAT_MOD=true


# ══════════════════════════════════════════════════════════════════════════════
# WEB BOT AUTHENTICATION (WBA)
# Consumed by: Lightpanda browser engine (--web_bot_auth_* flags)
#              and CI/CD workflows (.github/workflows/)
# ══════════════════════════════════════════════════════════════════════════════

# RSA private key (PEM format) used to sign Web Bot Auth challenge responses.
# Multi-line PEM: wrap in double quotes or use Doppler's multiline secret type.
# Example:
#   WBA_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
WBA_PRIVATE_KEY_PEM=

# The key identifier string that accompanies the signed challenge.
# Provided by the WBA domain operator.
WBA_KEY_ID=

# The domain for which the Web Bot Auth key is registered.
# Example: demo-browser.lightpanda.io
WBA_DOMAIN=


# ══════════════════════════════════════════════════════════════════════════════
# AWS ARTIFACT STORAGE
# Consumed by: CI/CD workflows (build.yml, e2e-test.yml)
# ══════════════════════════════════════════════════════════════════════════════

# AWS credentials for uploading nightly build artifacts to S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=us-east-1


# ══════════════════════════════════════════════════════════════════════════════
# LIGHTPANDA RUNTIME
# Consumed by: src/ (browser engine)
# ══════════════════════════════════════════════════════════════════════════════

# Set to "true" to disable anonymous telemetry pings sent to Lightpanda.
# Always true in CI. Can be set per-developer preference locally.
LIGHTPANDA_DISABLE_TELEMETRY=true
